# MCP Toolbox image with the RetailForge tools.yaml baked in, for Cloud Run.
# The toolbox base is distroless (no shell), so the binary is invoked directly
# and bound to Cloud Run's default container port (8080).
FROM us-central1-docker.pkg.dev/database-toolbox/toolbox/toolbox:latest

COPY toolbox/tools.yaml /config/tools.yaml

ENTRYPOINT ["/toolbox", "--tools-file", "/config/tools.yaml", "--address", "0.0.0.0", "--port", "8080"]
