# ─────────────────────────────────────────────────────────────────────────────
# RetailForge environment configuration
# Copy to `.env` and fill in your values.  NEVER commit the real .env file.
# ─────────────────────────────────────────────────────────────────────────────

# --- MongoDB Atlas -----------------------------------------------------------
# A cluster connection string WITH Atlas Vector Search enabled.
# Example: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DATABASE="retailforge"

# --- Gemini / Google GenAI ---------------------------------------------------
# Option A (simplest): Google AI Studio API key (https://aistudio.google.com/apikey)
GOOGLE_API_KEY="<your-gemini-api-key>"
GOOGLE_GENAI_USE_VERTEXAI="FALSE"

# Option B (Vertex AI): set USE_VERTEXAI=TRUE and provide project/location instead of API key
# GOOGLE_GENAI_USE_VERTEXAI="TRUE"
# GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
# GOOGLE_CLOUD_LOCATION="us-central1"

# --- Models ------------------------------------------------------------------
ROOT_AGENT_MODEL="gemini-2.5-flash"
SUB_AGENT_MODEL="gemini-2.5-flash"
EMBEDDING_MODEL="gemini-embedding-001"
EMBEDDING_DIMENSIONS="3072"

# --- MCP Toolbox -------------------------------------------------------------
# URL of the running genai-toolbox server (local default below).
TOOLBOX_URL="http://127.0.0.1:5000"

# --- AG-UI backend -----------------------------------------------------------
# Comma-separated list of allowed CORS origins for the FastAPI AG-UI endpoint.
FRONTEND_ORIGINS="http://localhost:3000"
